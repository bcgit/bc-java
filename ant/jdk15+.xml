<?xml version="1.0" encoding="UTF-8"?>

<project name="crypto1.5" default="build" basedir="..">

    <!-- Load release.* here (release.debug, release.suffix, ...) so target.prefix can react to
         release.debug below; bc+-build.xml re-loads these harmlessly as Ant properties are immutable.
         User overrides are read first so they win. -->
    <property file="bc-build.user.properties"/>
    <property file="bc-build.properties"/>

    <property name="bc.javac.source" value="1.5" />
    <property name="bc.javac.target" value="1.5" />
    <property name="build.dir" value="build" />
    <property name="jdk.name" value="jdk1.5" />
    <property name="artifacts.dir" value="${build.dir}/artifacts/${jdk.name}" />
    <property name="src.dir" value="${build.dir}/${jdk.name}" />
    <!-- A debug build (release.debug=true, set in bc-build.properties / bc-build.user.properties)
         labels its jars <module>-debug-jdk15to18-<version>; otherwise <module>-jdk15to18-<version>. -->
    <condition property="target.prefix" value="debug-jdk15to18" else="jdk15to18">
        <istrue value="${release.debug}"/>
    </condition>
    <property name="javadoc.args" value="-breakiterator" />
    <property name="jmail.present" value="true" />
    <property name="junit.maxmemory" value="1536m" />

    <target name="clean">
        <delete dir="${build.dir}" />
    </target>

    <target name="init">
        <mkdir dir="${src.dir}" />
        <mkdir dir="${artifacts.dir}" />
        <mkdir dir="${artifacts.dir}/reports" />
        <mkdir dir="${artifacts.dir}/reports/xml" />
        <mkdir dir="${artifacts.dir}/reports/html" />
        <mkdir dir="${artifacts.dir}/jars" />
        <mkdir dir="${artifacts.dir}/checkstyle" />
        <copy todir="${src.dir}">
            <fileset dir="core/src/main/java" includes="**/*.java" />
            <fileset dir="core/src/main/java" includes="**/*.properties" />
            <fileset dir="core/src/main/resources" includes="**/*.properties" />
            <fileset dir="core/src/main/javadoc" includes="**/*.html" />
            <fileset dir="core/src/test/java" includes="**/*.java" >
                <exclude name="**/crypto/faest/*.java"/>
                <exclude name="**/crypto/lms/*.java"/>
                <exclude name="**/crypto/mayo/*.java"/>
                <exclude name="**/crypto/sdith/*.java"/>
            </fileset>
            <fileset dir="core/src/test/javadoc" includes="**/*.html" />
            <fileset dir="core/src/test/resources" includes="**/*.*" />

            <fileset dir="prov/src/main/java" includes="**/*.java" />
            <fileset dir="prov/src/main/javadoc" includes="**/*.html" />
            <fileset dir="prov/src/main/resources" includes="**/*.properties" />
            <fileset dir="prov/src/test/java" includes="**/*.java" >
                <exclude name="**/jce/provider/*.java"/>
                <!-- AEADTest references javax.crypto.spec.GCMParameterSpec (JDK 7+) directly -->
                <exclude name="**/jce/provider/test/AEADTest.java"/>
                <!-- ChaCha20Poly1305Test / XChaCha20Poly1305Test drive AEAD AAD through
                     javax.crypto.Cipher.updateAAD (JDK 7+), which has no JRE 5 substitute; the
                     jdk1.5 RegressionTest overlay drops ChaCha20Poly1305Test to match. -->
                <exclude name="**/jce/provider/test/ChaCha20Poly1305Test.java"/>
                <exclude name="**/jce/provider/test/XChaCha20Poly1305Test.java"/>
                <!-- LEATest references javax.crypto.spec.GCMParameterSpec (JDK 7+) directly;
                     the jdk1.5 AllTests overlay drops it from the suite -->
                <exclude name="**/jcajce/provider/test/LEATest.java"/>
                <!-- X509LDAPCertStoreTest depends on unboundid-ldapsdk (JDK 7 bytecode);
                     not referenced by the jdk1.5 RegressionTest overlay -->
                <exclude name="**/jce/provider/test/X509LDAPCertStoreTest.java"/>
            </fileset>
            <fileset dir="prov/src/test/resources" includes="**/*.*" />

            <fileset dir="tls/src/main/java" includes="**/*.java" />
            <fileset dir="tls/src/main/javadoc" includes="**/*.html" />
            <fileset dir="tls/src/test/java" includes="**/*.java" >
                <exclude name="**/tls/*.java"/>
                <exclude name="**/jsse/provider/*.java"/>
                <!-- These two JSSE tests use JDK 1.8+ types (SNIHostName, ExtendedSSLSession,
                     SSLParameters SNI methods); the jdk1.5 jsse/provider AllTests overlay runs a
                     curated 1.5-safe subset that does not reference them. -->
                <exclude name="**/jsse/provider/test/BCJSSEClientTest.java"/>
                <exclude name="**/jsse/provider/test/RequestedServerNamesTest.java"/>
                <!-- TlsClientRawKeysTest / TlsServerRawKeysTest call InetAddress.getLoopbackAddress()
                     (JDK 1.7+); they belong to no AllTests/RegressionTest suite (run standalone), so
                     a plain exclude removes them from the compile with no coverage impact. -->
                <exclude name="**/tls/test/TlsClientRawKeysTest.java"/>
                <exclude name="**/tls/test/TlsServerRawKeysTest.java"/>
            </fileset>

            <fileset dir="pkix/src/main/java" includes="**/*.java" />
            <fileset dir="pkix/src/main/javadoc" includes="**/*.html" />
            <fileset dir="pkix/src/main/resources" includes="**/*.properties" />
            <fileset dir="pkix/src/test/java" includes="**/*.java" >
                <!-- est.jcajce tests reach the package-private DefaultESTClient; run from the test
                     jar in this build that cross-jar package access fails, so exclude them -->
                <exclude name="**/est/jcajce/*.java"/>
                <!-- Genuine post-1.5 API in test source (fails the real javac 1.5 test compile):
                     PKIXRevocationTest / OCSPExceptionalSignatureRejectionTest use
                     java.security.cert.PKIXRevocationChecker (JDK 1.8+); the jdk1.5 ocsp AllTests
                     overlay already omits them from the suite. -->
                <exclude name="**/cert/ocsp/test/PKIXRevocationTest.java"/>
                <exclude name="**/cert/ocsp/test/OCSPExceptionalSignatureRejectionTest.java"/>
                <!-- cert.plants (Merkle-tree certs) uses generic/varargs inference the 1.5 compiler
                     cannot resolve; excluded wholesale as in ant/jdk14.xml. -->
                <exclude name="**/cert/plants/**/*.java"/>
                <!-- DefiniteLengthLargeDataTest uses PipedInputStream(out, int) (JDK 1.6+); it is
                     referenced by no suite, so a plain exclude suffices. -->
                <exclude name="**/cms/test/DefiniteLengthLargeDataTest.java"/>
                <!-- ERSTest uses java.nio.file.Files (JDK 1.7+); the jdk1.5 tsp AllTests overlay
                     drops it while retaining ERSTestdatenTest. -->
                <exclude name="**/tsp/test/ERSTest.java"/>
            </fileset>
            <fileset dir="pkix/src/test/javadoc" includes="**/*.html" />
            <fileset dir="pkix/src/test/resources" includes="**/*.*" />

            <fileset dir="pg/src/main/java" includes="**/*.java" />
            <fileset dir="pg/src/main/javadoc" includes="**/*.html" />
            <fileset dir="pg/src/main/java" includes="**/*.properties" />
            <fileset dir="pg/src/test/java" includes="**/*.java" />
            <fileset dir="pg/src/test/resources" includes="**/*.*" />

            <fileset dir="util/src/main/java" includes="**/*.java" />
            <fileset dir="util/src/main/javadoc" includes="**/*.html" />
            <fileset dir="util/src/main/java" includes="**/*.properties" />
            <fileset dir="util/src/test/java" includes="**/*.java" />
            <fileset dir="util/src/test/resources" includes="**/*.*" />

            <fileset dir="mail/src/main/java" includes="**/*.java" />
            <fileset dir="mail/src/main/javadoc" includes="**/*.html" />
            <fileset dir="mail/src/main/resources" includes="**/*.properties" />
            <fileset dir="mail/src/main/resources" includes="**/mailcap" />
            <fileset dir="mail/src/test/java" includes="**/*.java" />
            <fileset dir="mail/src/test/resources" includes="**/*.*" />

        </copy>
        <copy todir="${src.dir}" overwrite="true">
            <fileset dir="core/src/main/jdk1.5" includes="**/*.java" />
            <fileset dir="mail/src/main/jdk1.5" includes="**/*.java" />
            <fileset dir="prov/src/main/jdk1.5" includes="**/*.java" />
            <fileset dir="prov/src/test/jdk1.5" includes="**/*.java" />
            <fileset dir="pkix/src/main/jdk1.5" includes="**/*.java" />
            <fileset dir="pkix/src/test/jdk1.5" includes="**/*.java" />
            <fileset dir="tls/src/main/jdk1.5" includes="**/*.java" />
            <fileset dir="tls/src/test/jdk1.5" includes="**/*.java" />
            <fileset dir="pg/src/main/jdk1.5" includes="**/*.java" />
            <fileset dir="pg/src/test/jdk1.5" includes="**/*.java" />
        </copy>

        <!-- jdk15to18 has no full source preprocessor (unlike ant/jdk14.xml), but two annotations
             are genuine javac 1.5 compile errors in the test tree: @Override on an interface-method
             implementation ("method does not override a method from its superclass") and
             @FunctionalInterface (a Java 8 type, "cannot find symbol"). Both are compile-time only,
             so stripping them from the staged sources changes nothing at runtime. This mirrors the
             @Override|@FunctionalInterface strip in ant/build.regexp used by ant/jdk14.xml. -->
        <replaceregexp match="@Override|@FunctionalInterface" replace=" " flags="g" byline="true">
            <fileset dir="${src.dir}" includes="**/*.java" />
        </replaceregexp>

        <available classname="com.puppycrawl.tools.checkstyle.CheckStyleTask" property="checkstyle.on" />
    </target>

    <target name="checkstyle-on" if="checkstyle.on">
        <taskdef resource="checkstyletask.properties" />
        <checkstyle config="checkstyle/bc-checks.xml">
            <fileset dir="${src.dir}">
                <include name="**/*.java"/>
            </fileset>
            <formatter type="plain"/>
            <formatter type="xml" toFile="${artifacts.dir}/checkstyle/${jdk.name}-errors.xml"/>
        </checkstyle>
    </target>
    
    <target name="checkstyle-off" unless="checkstyle.on">
    </target>
    
    <target name="build" depends="init">
        <ant antfile="ant/bc+-build.xml" dir="." target="build-util" />
        <ant antfile="ant/bc+-build.xml" dir="." target="build-tls" />
        <ant antfile="ant/bc+-build.xml" dir="." />
        <ant antfile="ant/bc+-build.xml" dir="." target="build-jmail" />
        <ant antfile="ant/bc+-build.xml" dir="." target="javadoc-lw" />
        <ant antfile="ant/bc+-build.xml" dir="." target="javadoc-libraries" />
        <ant antfile="ant/bc+-build.xml" dir="." target="javadoc-tls" />
    </target>

    <target name="build-lw" depends="init">
        <ant antfile="ant/bc+-build.xml" dir="." target="build-lw" />
        <ant antfile="ant/bc+-build.xml" dir="." target="javadoc-lw" />
    </target>

    <target name="build-provider" depends="init, checkstyle-on, checkstyle-off">
        <ant antfile="ant/bc+-build.xml" dir="." target="build-provider" />
        <ant antfile="ant/bc+-build.xml" dir="." target="javadoc-provider" />
    </target>

    <target name="build-test" depends="init">
        <ant antfile="ant/bc+-build.xml" dir="." target="build-test" />
    </target>

    <target name="test" depends="build-test">
        <ant antfile="ant/bc+-build.xml" dir="." target="test" />
    </target>

    <target name="test-lw" depends="build-test">
        <ant antfile="ant/bc+-build.xml" dir="." target="test-lw" />
    </target>

    <target name="zip-src">
        <ant antfile="ant/bc+-build.xml" dir="." target="zip-src" />
    </target>
</project>
